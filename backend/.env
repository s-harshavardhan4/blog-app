# ─────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY
# On Render, set these as Environment Variables in dashboard
# ─────────────────────────────────────────────────────────

PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/blog_db?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/blog_db?retryWrites=true&w=majority

# Strong random string — e.g. run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# Your frontend URL (used for CORS) — e.g. https://blog-frontend.onrender.com
# Leave as * for local dev
FRONTEND_URL=*

NODE_ENV=development
